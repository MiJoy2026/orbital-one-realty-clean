generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())

  stripeSessionId   String   @unique
  propertyId        String
  propertyType      String
  acreagePurchased  Float?
  lunarState        String

  deedName          String

  certificateNumber String   @unique

  amountPaid        Float

  paymentStatus     String

  email             String?
  userId String?
  user   User? @relation(fields: [userId], references: [id])

  premiumGoldSeal   Boolean  @default(false)

  passportPurchased Boolean  @default(false)
  isGift            Boolean  @default(false)
  recipientEmail String?
  giftMessage    String?
  hoaClaimed     Boolean @default(false)
}

model LunarState {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String   @unique
  theme       String?
  description String?

  cities      LunarCity[]
  towns       LunarTown[]
}

model LunarCity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  stateName String

  state     LunarState @relation(fields: [stateName], references: [name])

  @@unique([name, stateName])
}

model LunarTown {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  stateName String

  state     LunarState @relation(fields: [stateName], references: [name])

  @@unique([name, stateName])
}

model Property {
  id          String   @id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  state       String
  city   String?
  town   String?

  type        String
  size        String
  price       Float
  status      String   @default("Available")

  mapX   Float?
  mapY   Float?
}

model StateInventory {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stateName   String   @unique
  totalAcres  Float    @default(50000)
  soldAcres   Float    @default(0)
}
model AcreageAllocation {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())

  orderId           String
  certificateNumber String

  stateName         String
  propertyId        String

  startingAcre      Int
  endingAcre        Int
  acresAssigned     Float
}
model User {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  email        String   @unique
  passwordHash String

  name         String?

  orders       Order[]
  members Member[]
  
}
model Member {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  name          String
  email         String   @unique

  hoaNumber     String   @unique
  charterMember Boolean  @default(true)

  activatedAt   DateTime?

  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
}